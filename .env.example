# Job Search Navigator — Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Database
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
DATABASE_SERVER=localhost

# Authentication tokens (generate strong random strings)
# TRACKER_TOKEN: used for browser/user access
# INGEST_TOKEN: used for Claude agents to write back to the database
TRACKER_TOKEN=your_tracker_token_here
INGEST_TOKEN=your_ingest_token_here

# Adzuna API (for job discovery sweep)
# Get free API credentials at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Email (for daily report delivery)
REPORT_EMAIL=your-email@example.com

# Site URL (for email links and agent callbacks)
SITE_URL=https://yourdomain.com/tracker
